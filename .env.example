# Environment Configuration for quran-web
# 
# This file documents environment variables used across different contexts:
# 1. Local Development (copy this file to .env for local use)
# 2. GitHub Actions Deployment (configured as Variables in repository settings)
# 3. Production Cloudflare Pages (configured in Cloudflare dashboard)

# ==============================================================================
# LOCAL DEVELOPMENT
# ==============================================================================
# Copy this file to .env for local development
# Run: npm run dev

# API Configuration (local development)
NUXT_QURAN_API_URL=http://localhost:8787
NUXT_PUBLIC_ASSETS_BASE_URL=https://assets.quran.in.th

# ==============================================================================
# GITHUB ACTIONS DEPLOYMENT
# ==============================================================================
# These are configured in GitHub repository settings:
# Settings → Secrets and variables → Actions → Variables tab
#
# REQUIRED VARIABLES:
#   QURAN_API_URL          - Production API URL (e.g., https://api.quran.in.th)
#   ASSETS_BASE_URL        - CDN/assets base URL (e.g., https://assets.quran.in.th)
#
# OPTIONAL VARIABLES:
#   PAGES_PROJECT_NAME     - Cloudflare Pages project name (default: quran-web)
#   NODE_VERSION           - Node.js version (default: 20)
#
# SECRETS (configured in Secrets tab):
#   CLOUDFLARE_API_TOKEN   - Cloudflare API token
#   CLOUDFLARE_ACCOUNT_ID  - Your Cloudflare account ID
#
# Example GitHub Variables:
#   QURAN_API_URL=https://api.quran.in.th
#   ASSETS_BASE_URL=https://assets.quran.in.th
#   PAGES_PROJECT_NAME=quran-web
#   NODE_VERSION=20

# ==============================================================================
# PRODUCTION (Cloudflare Pages)
# ==============================================================================
# Production environment variables are set in Cloudflare Dashboard:
# Workers & Pages → quran-web → Settings → Environment Variables
#
# Add these production variables:
#   NUXT_QURAN_API_URL=https://api.quran.in.th
#   NUXT_PUBLIC_ASSETS_BASE_URL=https://assets.quran.in.th

# ==============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
# ==============================================================================

# Development (local):
# NUXT_QURAN_API_URL=http://localhost:8787
# NUXT_PUBLIC_ASSETS_BASE_URL=https://assets.quran.in.th

# Staging:
# NUXT_QURAN_API_URL=https://staging-api.quran.in.th
# NUXT_PUBLIC_ASSETS_BASE_URL=https://staging-assets.quran.in.th

# Production:
# NUXT_QURAN_API_URL=https://api.quran.in.th
# NUXT_PUBLIC_ASSETS_BASE_URL=https://assets.quran.in.th

# ==============================================================================
# NUXTC CONFIG REFERENCE
# ==============================================================================
# These are mapped in nuxt.config.ts:
#
# runtimeConfig: {
#   // Server-side (private, not exposed to client)
#   quranApiUrl: 'http://localhost:8787',
#   public: {
#     // Client-side (exposed to browser)
#     assetsBaseUrl: 'https://assets.quran.in.th',
#   },
# }

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# - Public variables (NUXT_PUBLIC_*) are exposed to the browser
# - Private variables (server-side only) are not exposed
# - Never commit actual secrets or production values
# - Add .env to .gitignore (already done)

# For setup instructions, see:
# - docs/CLOUDFLARE_DEPLOYMENT_SETUP.md
# - docs/GITHUB_VARIABLES_SETUP.md
# - docs/GITHUB_CONFIG_QUICKREF.md
